DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/absolute/path/to/media

POSTGRES_DB=yalla_db
POSTGRES_USER=yalla_user
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
DEFAULT_FROM_EMAIL=no-reply@example.com

AUTH_OTP_EXPIRY_SECONDS=300
AUTH_OTP_COOLDOWN_SECONDS=60
AUTH_OTP_TARGET_LIMIT=3
AUTH_OTP_TARGET_WINDOW_SECONDS=600
AUTH_OTP_IP_LIMIT=10
AUTH_OTP_IP_WINDOW_SECONDS=3600
